# Auth0 Configuration
AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_AUDIENCE=https://your-api.example.com
AUTH0_CLIENT_ID=your-spa-client-id

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Configuration (same for local, RDS for AWS)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-users:5432/tdse_users
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=rootpassword

# Logging
JPA_SHOW_SQL=false

# AWS Region (for Lambda deployment)
AWS_REGION=us-east-1

# Service URLs (for inter-service communication in Lambda)
USER_SERVICE_URL=https://your-user-service-lambda-url
POSTS_SERVICE_URL=https://your-posts-service-lambda-url
