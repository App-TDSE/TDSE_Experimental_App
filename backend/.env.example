# Auth0 tenant domain (without https:// prefix)
# Example: dev-abc123xy.us.auth0.com
AUTH0_DOMAIN=*****

# Auth0 API identifier (the "audience" you created in Auth0 -> APIs)
# Example: https://myapp.api
AUTH0_AUDIENCE=*****

# Auth0 SPA client ID (used by Swagger UI for PKCE login)
# Found in Auth0 -> Applications -> Your SPA -> Settings -> Client ID
AUTH0_CLIENT_ID=*****