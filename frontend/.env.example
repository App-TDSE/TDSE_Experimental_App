# Your Auth0 tenant domain
# Same AUTH_DOMAIN in the backend .env
VITE_AUTH0_DOMAIN=*****

# The Client ID of your SPA application
VITE_AUTH0_CLIENT_ID=*****

# The API audience identifier (must match your backend's AUTH0_AUDIENCE)
VITE_AUTH0_AUDIENCE=*****

# Single API base URL (optional).
# - In local dev, leave empty to use Vite proxy (/api -> microservices).
# - In production, set this only if all routes are behind one gateway.
VITE_API_BASE=

# Per-service API bases.
# - Leave empty in local dev so the Vite proxy handles /api/*.
# - In production, set each deployed API Gateway URL here if the services are separate.
VITE_USERS_API_BASE=
VITE_POSTS_API_BASE=
VITE_STREAM_API_BASE=